# ─── Copy this file to .env and fill in your real values ───
# NEVER commit .env to Git — it is listed in .gitignore

PORT=3000

# MongoDB Atlas connection string (or local: mongodb://localhost:27017/umassboston)
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/umassboston?retryWrites=true&w=majority

# Google Maps API key (keep this server-side and serve it via /api/maps-key if needed)
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_KEY_HERE

# Anthropic API key (for the Harbor chatbot backend endpoint)
ANTHROPIC_API_KEY=sk-ant-...

# CORS — set to your production domain in production
ALLOWED_ORIGIN=http://localhost:3000
